# --- Discord Bot ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# --- Virtual audio devices ---
# Device A: playback device Discord audio is WRITTEN to (Chrome mic reads the paired recording side).
#   e.g. "CABLE-A Input (VB-Audio Virtual Cable A)"
DISCORD_TO_GPT_DEVICE=
# Device B: recording device ChatGPT Live's audio is READ from (Chrome output must target the paired playback side).
#   e.g. "CABLE-B Output (VB-Audio Virtual Cable B)"
GPT_TO_DISCORD_DEVICE=

# --- Audio format ---
INPUT_SAMPLE_RATE=48000
INPUT_CHANNELS=2

OUTPUT_SAMPLE_RATE=48000
OUTPUT_CHANNELS=2

# --- Logging ---
# one of: debug, info, warn, error
LOG_LEVEL=info

# --- Voice activity / anti-howling ---
# RMS amplitude threshold (0-1) below which audio is considered silence
VOICE_ACTIVITY_THRESHOLD=0.02
# How long to keep gating Discord->GPT audio after GPT stops speaking (ms)
GPT_SPEAKING_HOLD_MS=500
# Whether to duck (attenuate) Discord->GPT audio while GPT is speaking, instead of muting it fully
DISCORD_INPUT_DUCKING=true
# Attenuation level (0-1) applied to Discord->GPT audio while ducking is active
DISCORD_INPUT_DUCKING_LEVEL=0.1

# --- Smart barge-in ---
# Discord's speaking event starts capture, then local PCM VAD confirms sustained speech before
# opening Discord->GPT and ducking GPT playback.
BARGE_IN_ENABLED=true
# GPT->Discord playback gain during barge-in (0=silent, 1=unchanged)
BARGE_IN_GPT_PLAYBACK_LEVEL=0.2
# Discord PCM RMS threshold (0-1). Raise this if fans/air conditioners cause false barge-ins.
BARGE_IN_VOICE_THRESHOLD=0.025
# Voice must stay above the threshold this long before barge-in starts (filters coughs/clicks).
BARGE_IN_ATTACK_MS=100
# Keep barge-in active this long after the last above-threshold frame (bridges gaps between words).
BARGE_IN_RELEASE_MS=400

# --- Air-reading prompt ---
# /airprompt shows the instruction to paste into ChatGPT Live. The Chrome audio bridge cannot
# inject this automatically, so it must be configured in ChatGPT before the conversation.
AIR_READING_ENABLED=true
# Optional one-line override. Use literal \n sequences for line breaks.
# AIR_READING_PROMPT=

# --- Voice-triggered Discord text posting (local Whisper speech-to-text, no external API) ---
# When a Discord speaker says one of MESSAGE_POST_TRIGGER_KEYWORDS, ChatGPT Live's next spoken
# reply is transcribed and posted to MESSAGE_POST_CHANNEL_ID. Off by default: enabling downloads
# a Whisper model (~a few hundred MB) on first use and adds noticeable CPU load while transcribing.
MESSAGE_POST_ENABLED=false
MESSAGE_POST_CHANNEL_ID=
# Comma-separated list of phrases that, if found anywhere in a transcribed utterance, trigger posting.
# Includes hiragana readings alongside kanji since Whisper's kanji-vs-kana output is inconsistent
# for the same spoken words - matching only the kanji form misses a meaningful fraction of hits.
MESSAGE_POST_TRIGGER_KEYWORDS=投稿して,とうこうして,送信して,そうしんして,送って,おくって
# How long ChatGPT Live's reply must stay silent before it's considered finished for capture
# purposes (ms). Deliberately longer than GPT_SPEAKING_HOLD_MS: that one only needs to reopen
# Discord's mic promptly, but this one must not cut off mid-sentence during natural speech pauses.
MESSAGE_POST_REPLY_HOLD_MS=1500

# --- Conversation transcript logging (local Whisper speech-to-text, no external API) ---
# Records both directions to per-utterance temporary PCM files, then
# transcribes and saves the whole conversation only after /stop or /leave. Because transcription
# happens after the live conversation ends, it can safely use a larger/slower/more accurate
# Whisper model than the live features above without affecting anything real-time.
TRANSCRIPT_LOG_ENABLED=false
# Save the transcript to a local text file under TRANSCRIPT_LOG_DIR
TRANSCRIPT_LOG_TO_FILE=true
TRANSCRIPT_LOG_DIR=logs
# Also post the transcript as a new thread under this text channel
TRANSCRIPT_LOG_TO_THREAD=false
TRANSCRIPT_LOG_CHANNEL_ID=
# Same rationale as MESSAGE_POST_REPLY_HOLD_MS: how long ChatGPT Live must stay silent before an
# utterance is considered finished and recorded as one line, rather than being cut off mid-reply.
TRANSCRIPT_GPT_UTTERANCE_HOLD_MS=1500

# --- /feed: post Discord feedback to a GitHub Issue (Issue #7 Phase 1-2a) ---
# /feed is registered unconditionally, but only works once both values below are set - without
# them it fails with a clear ConfigError instead of at bot startup. Classification is a fixed
# local keyword rule set, and similar-issue matching uses a local sentence-embedding model (no
# external AI API either way). Issues are created/commented immediately with NO human review
# step - see README section 21 before enabling this on a public repository.
# Fine-grained PAT scoped to just this repository, "Issues: Read and write" permission only.
GITHUB_TOKEN=
# "owner/repo" of the repository /feed should create issues in.
GITHUB_REPO=
# Cosine similarity (0-1) an open issue must reach before /feed comments on it instead of
# creating a new issue. Picked from real-model measurements (README section 21); still not a
# permanently validated constant - keep tuning from real usage.
FEED_SIMILARITY_THRESHOLD=0.65
