{
  "name": "discord-gptlive-bridge",
  "version": "0.1.0",
  "description": "Discord VC <-> ChatGPT Live (Chrome, manual) audio bridge using virtual audio cables",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "register": "tsx src/discord/command-register.ts",
    "devices": "tsx src/audio/device-list.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "tsx --test src/state/bridge-state.test.ts src/services/bridge-service.test.ts src/services/feedback-classifier.test.ts src/services/feedback-content.test.ts src/services/feedback-service.test.ts src/state/feed-cooldown.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@huggingface/transformers": "^4.2.0",
    "audify": "^1.10.1",
    "discord.js": "^14.26.5",
    "dotenv": "^17.4.2",
    "libsodium-wrappers": "^0.8.4",
    "opusscript": "^0.0.8",
    "prism-media": "^1.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/node": "^24.0.0",
    "eslint": "^9.19.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  }
}
